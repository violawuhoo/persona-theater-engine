{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "archetype.schema.json",
  "title": "Archetype Schema",
  "type": "object",
  "required": [
    "id",
    "version",
    "slug",
    "name",
    "seed_source",
    "source_profile",
    "quadrants",
    "parameter_space",
    "model_core",
    "style_profile",
    "assets",
    "constraints",
    "generation_contract",
    "summary",
    "axis_explanations",
    "scene_playbook"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ARCHETYPE_[0-9]{2,}$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string"
    },
    "name": {
      "type": "object",
      "required": [
        "cn",
        "en"
      ],
      "properties": {
        "cn": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "seed_source": {
      "type": "object",
      "required": [
        "markdown_path",
        "authority"
      ],
      "properties": {
        "markdown_path": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source_profile": {
      "type": "object",
      "required": [
        "derived_from",
        "source_template"
      ],
      "properties": {
        "derived_from": {
          "type": "string"
        },
        "source_template": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "model_core": {
      "type": "object",
      "required": [
        "core_essence",
        "social_stance",
        "interaction_logic",
        "emotional_logic",
        "power_logic",
        "motivation",
        "core_fear"
      ],
      "properties": {
        "core_essence": {
          "type": "string"
        },
        "social_stance": {
          "type": "string"
        },
        "interaction_logic": {
          "type": "string"
        },
        "emotional_logic": {
          "type": "string"
        },
        "power_logic": {
          "type": "string"
        },
        "motivation": {
          "type": "string",
          "description": "One sentence — what this archetype is chasing."
        },
        "core_fear": {
          "type": "string",
          "description": "One sentence — what would make this archetype collapse."
        }
      },
      "additionalProperties": false
    },
    "quadrants": {
      "type": "object",
      "required": [
        "E",
        "O",
        "R",
        "B"
      ],
      "properties": {
        "E": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "O": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "R": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "B": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "parameter_space": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "min",
          "max"
        ],
        "properties": {
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "style_profile": {
      "type": "object",
      "required": [
        "behavior_style",
        "language_style"
      ],
      "properties": {
        "behavior_style": {
          "type": "string"
        },
        "language_style": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "required": [
        "slogan",
        "signature_lines_pool",
        "reaction_patterns_pool"
      ],
      "properties": {
        "slogan": {
          "type": "string"
        },
        "signature_lines_pool": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reaction_patterns_pool": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "required": [
        "forbidden_drift"
      ],
      "properties": {
        "forbidden_drift": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "generation_contract": {
      "$ref": "generation_contract.schema.json"
    },
    "summary": {
      "type": "string"
    },
    "axis_explanations": {
      "type": "object",
      "required": ["E", "O", "R", "B"],
      "properties": {
        "E": { "type": "string" },
        "O": { "type": "string" },
        "R": { "type": "string" },
        "B": { "type": "string" }
      },
      "additionalProperties": false,
      "description": "What each quadrant value means in observable behavior, authored per archetype."
    },
    "scene_playbook": {
      "type": "object",
      "description": "Per-scene authored hero sentence. Keys must match SCENARIO_OVERLAYS labels in docs/constants.js.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
