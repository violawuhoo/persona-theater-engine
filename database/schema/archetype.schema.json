{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "archetype.schema.json",
  "title": "Archetype Schema",
  "type": "object",
  "required": [
    "id",
    "slug",
    "name",
    "seed_source",
    "positioning",
    "core_traits",
    "parameter_space",
    "core_logic",
    "constraints",
    "generation_contract",
    "expression_style",
    "field_effect",
    "inner_outer_model",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ARCHETYPE_[0-9]{2,}$"
    },
    "slug": {
      "type": "string"
    },
    "name": {
      "type": "object",
      "required": [
        "cn",
        "en"
      ],
      "properties": {
        "cn": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "seed_source": {
      "type": "object",
      "required": [
        "markdown_path",
        "authority"
      ],
      "properties": {
        "markdown_path": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "positioning": {
      "type": "object",
      "required": [
        "thesis",
        "mechanism"
      ],
      "properties": {
        "thesis": {
          "type": "string"
        },
        "mechanism": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "core_traits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parameter_space": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "min",
          "max"
        ],
        "properties": {
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "core_logic": {
      "type": "object",
      "required": [
        "core_motivation",
        "power_logic",
        "social_logic",
        "emotion_logic",
        "security_anchor",
        "relationship_model"
      ],
      "properties": {
        "core_motivation": {
          "type": "string"
        },
        "power_logic": {
          "type": "string"
        },
        "social_logic": {
          "type": "string"
        },
        "emotion_logic": {
          "type": "string"
        },
        "security_anchor": {
          "type": "string"
        },
        "relationship_model": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "required": [
        "must_have",
        "must_not_have",
        "forbidden_drift"
      ],
      "properties": {
        "must_have": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_not_have": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_drift": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "generation_contract": {
      "$ref": "generation_contract.schema.json"
    },
    "expression_style": {
      "type": "object",
      "required": [
        "verbal",
        "physical"
      ],
      "properties": {
        "verbal": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "physical": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "field_effect": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inner_outer_model": {
      "type": "object",
      "required": [
        "outer_layer",
        "inner_layer"
      ],
      "properties": {
        "outer_layer": {
          "type": "string"
        },
        "inner_layer": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
