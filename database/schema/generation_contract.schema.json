{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "generation_contract.schema.json",
  "title": "Generation Contract Schema",
  "type": "object",
  "required": [
    "locked_fields",
    "support_fields",
    "expansion_zones",
    "forbidden_drift"
  ],
  "properties": {
    "locked_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/field_rule"
      }
    },
    "support_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/field_rule"
      }
    },
    "expansion_zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/expansion_zone"
      }
    },
    "forbidden_drift": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "field_rule": {
      "type": "object",
      "required": [
        "field",
        "reason"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "expansion_zone": {
      "type": "object",
      "required": [
        "zone",
        "guidance"
      ],
      "properties": {
        "zone": {
          "type": "string"
        },
        "guidance": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
