{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "persona.schema.json",
  "title": "Persona Schema",
  "type": "object",
  "required": [
    "id",
    "version",
    "archetype_id",
    "name",
    "source_markdown",
    "consumer_fields",
    "theater_support",
    "realized_parameters",
    "generation_contract"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ARCH[0-9]{2}$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "archetype_id": {
      "type": "string",
      "pattern": "^ARCHETYPE_[0-9]{2,}$"
    },
    "name": {
      "type": "object",
      "required": [
        "primary",
        "en"
      ],
      "properties": {
        "primary": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "source_classification": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source_markdown": {
      "type": "string"
    },
    "consumer_fields": {
      "type": "object",
      "required": [
        "display_name",
        "quadrants",
        "slogan",
        "core_essence",
        "social_essence",
        "motivation",
        "core_fear",
        "axis_explanations",
        "signature_lines_pool",
        "taboos",
        "behavior_style",
        "language_style",
        "reaction_patterns_pool"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "quadrants": {
          "$ref": "#/definitions/quadrants"
        },
        "slogan": {
          "type": "string"
        },
        "core_essence": {
          "type": "string"
        },
        "social_essence": {
          "type": "string"
        },
        "motivation": {
          "type": "string",
          "description": "One sentence — what this persona is chasing. Phase 2 schema extension."
        },
        "core_fear": {
          "type": "string",
          "description": "One sentence — what would make this persona collapse / break character. Phase 2 schema extension."
        },
        "axis_explanations": {
          "$ref": "#/definitions/axis_explanations"
        },
        "signature_lines_pool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "taboos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "behavior_style": {
          "type": "string"
        },
        "language_style": {
          "type": "string"
        },
        "reaction_patterns_pool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "theater_support": {
      "type": "object",
      "required": [
        "logic_axes",
        "scene_tactics",
        "expression_modulators",
        "reaction_cues",
        "scene_playbook"
      ],
      "properties": {
        "logic_axes": {
          "type": "object",
          "required": [
            "interaction_focus",
            "emotional_guard",
            "power_move"
          ],
          "properties": {
            "interaction_focus": {
              "type": "string"
            },
            "emotional_guard": {
              "type": "string"
            },
            "power_move": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "scene_tactics": {
          "type": "object",
          "required": [
            "small_scale",
            "large_scale"
          ],
          "properties": {
            "small_scale": {
              "type": "string"
            },
            "large_scale": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "expression_modulators": {
          "type": "object",
          "required": [
            "delivery_mode",
            "physicality"
          ],
          "properties": {
            "delivery_mode": {
              "type": "string"
            },
            "physicality": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "reaction_cues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/reaction_cue"
          }
        },
        "scene_playbook": {
          "$ref": "#/definitions/scene_playbook"
        }
      },
      "additionalProperties": false
    },
    "realized_parameters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "value",
          "confidence",
          "evidence"
        ],
        "properties": {
          "value": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "generation_contract": {
      "$ref": "generation_contract.schema.json"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "quadrants": {
      "type": "object",
      "required": [
        "E",
        "O",
        "R",
        "B"
      ],
      "properties": {
        "E": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "O": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "R": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "B": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "reaction_cue": {
      "type": "object",
      "required": [
        "trigger",
        "guidance"
      ],
      "properties": {
        "trigger": {
          "type": "string"
        },
        "guidance": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "axis_explanations": {
      "type": "object",
      "required": [
        "E",
        "O",
        "R",
        "B"
      ],
      "properties": {
        "E": {
          "type": "string",
          "description": "What this persona's E value means in observable behavior."
        },
        "O": {
          "type": "string",
          "description": "What this persona's O value means in observable behavior."
        },
        "R": {
          "type": "string",
          "description": "What this persona's R value means in observable behavior."
        },
        "B": {
          "type": "string",
          "description": "What this persona's B value means in observable behavior."
        }
      },
      "additionalProperties": false
    },
    "scene_playbook": {
      "type": "object",
      "description": "Per-scene authored hero sentence: 'In this scene, this persona's primary tactic is X.' Keys must match SCENARIO_OVERLAYS labels in docs/constants.js. minProperties:1 — additional scenes may be added without schema changes.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "response_protocol": {
      "type": "object",
      "required": [
        "label",
        "cognitive_filter",
        "response_actions",
        "breaker_line",
        "logic"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "cognitive_filter": {
          "type": "string"
        },
        "response_actions": {
          "type": "string"
        },
        "breaker_line": {
          "type": "string"
        },
        "logic": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
