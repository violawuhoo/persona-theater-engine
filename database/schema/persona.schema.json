{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "persona.schema.json",
  "title": "Persona Schema",
  "type": "object",
  "required": [
    "id",
    "version",
    "archetype_id",
    "name",
    "source_markdown",
    "consumer_fields",
    "stable_fields",
    "soft_fields",
    "generation_contract"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ARCH[0-9]{2}$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "archetype_id": {
      "type": "string",
      "pattern": "^ARCHETYPE_[0-9]{2,}$"
    },
    "name": {
      "type": "object",
      "required": [
        "primary",
        "en"
      ],
      "properties": {
        "primary": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "source_classification": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source_markdown": {
      "type": "string"
    },
    "consumer_fields": {
      "type": "object",
      "required": [
        "display_name",
        "quadrants",
        "slogan",
        "core_essence",
        "social_essence",
        "signature_lines_pool",
        "taboos",
        "theater_logic",
        "behavior_style",
        "language_style",
        "reaction_patterns_pool"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "quadrants": {
          "$ref": "#/definitions/quadrants"
        },
        "slogan": {
          "type": "string"
        },
        "core_essence": {
          "type": "string"
        },
        "social_essence": {
          "type": "string"
        },
        "signature_lines_pool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "taboos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "theater_logic": {
          "type": "object",
          "required": [
            "core_drive",
            "interaction_logic",
            "emotional_logic",
            "power_logic"
          ],
          "properties": {
            "core_drive": {
              "type": "string"
            },
            "interaction_logic": {
              "type": "string"
            },
            "emotional_logic": {
              "type": "string"
            },
            "power_logic": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "behavior_style": {
          "type": "string"
        },
        "language_style": {
          "type": "string"
        },
        "reaction_patterns_pool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "stable_fields": {
      "type": "object",
      "required": [
        "identity",
        "core_directive",
        "core_logic",
        "embodiment",
        "taboos"
      ],
      "properties": {
        "identity": {
          "type": "object",
          "required": [
            "persona_name",
            "premise"
          ],
          "properties": {
            "persona_name": {
              "type": "string"
            },
            "subtitle": {
              "type": "string"
            },
            "premise": {
              "type": "string"
            },
            "source_classification": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "core_directive": {
          "type": "string"
        },
        "core_logic": {
          "type": "object",
          "required": [
            "social_essence",
            "self_positioning",
            "power_source"
          ],
          "properties": {
            "social_essence": {
              "type": "string"
            },
            "self_positioning": {
              "type": "string"
            },
            "power_source": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "embodiment": {
          "type": "object",
          "required": [
            "center_of_gravity",
            "gaze_protocol",
            "breathing_protocol",
            "hand_constraints"
          ],
          "properties": {
            "center_of_gravity": {
              "type": "string"
            },
            "gaze_protocol": {
              "type": "object",
              "required": [
                "focus_rule",
                "movement_rule"
              ],
              "properties": {
                "focus_rule": {
                  "type": "string"
                },
                "movement_rule": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "breathing_protocol": {
              "type": "string"
            },
            "hand_constraints": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "taboos": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "soft_fields": {
      "type": "object",
      "required": [
        "scene_behavior",
        "interaction_matrix"
      ],
      "properties": {
        "scene_behavior": {
          "type": "object",
          "required": [
            "small_scale",
            "large_scale"
          ],
          "properties": {
            "small_scale": {
              "$ref": "#/definitions/scene_block"
            },
            "large_scale": {
              "$ref": "#/definitions/scene_block"
            }
          },
          "additionalProperties": false
        },
        "interaction_matrix": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/interaction_rule"
          }
        }
      },
      "additionalProperties": false
    },
    "realized_parameters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "value",
          "confidence",
          "evidence"
        ],
        "properties": {
          "value": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "generation_contract": {
      "$ref": "generation_contract.schema.json"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "quadrants": {
      "type": "object",
      "required": [
        "E",
        "O",
        "R",
        "B"
      ],
      "properties": {
        "E": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "O": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "R": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "B": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "scene_block": {
      "type": "object",
      "required": [
        "label",
        "strategy",
        "actions",
        "logic"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "strategy": {
          "type": "string"
        },
        "actions": {
          "type": "string"
        },
        "logic": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "interaction_rule": {
      "type": "object",
      "required": [
        "input_signal",
        "interpretation",
        "response_adjustment"
      ],
      "properties": {
        "input_signal": {
          "type": "string"
        },
        "interpretation": {
          "type": "string"
        },
        "response_adjustment": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "response_protocol": {
      "type": "object",
      "required": [
        "label",
        "cognitive_filter",
        "response_actions",
        "breaker_line",
        "logic"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "cognitive_filter": {
          "type": "string"
        },
        "response_actions": {
          "type": "string"
        },
        "breaker_line": {
          "type": "string"
        },
        "logic": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
